# [ SERVER SETTINGS ]
# Standard port is 80 (so you don't have to type :5678 in the browser)
N8N_PORT=5678
N8N_PROTOCOL=http
# Change this to your Google Cloud External IP
N8N_HOST=34.xxx.xxx.xxx

# [ TIMEZONE SETTINGS ]
# This ensures your scheduled automations run at the correct Thai time
GENERIC_TIMEZONE=Asia/Bangkok
TZ=Asia/Bangkok

# [ SECURITY ]
# This is used to encrypt your credentials in the database. 
# Use a long random string.
N8N_ENCRYPTION_KEY=make_this_a_random_secure_string_123

# [ USER INTERFACE ]
# Optional: Gives your n8n instance a name
N8N_EDITOR_BASE_URL=http://34.xxx.xxx.xxx/

# The external address of your server
WEBHOOK_URL=http://your_external_ip/

# cloudflare token
# TUNNEL_TOKEN=your long token